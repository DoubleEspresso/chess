Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "razoring", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"1810", "-", 
        RowBox[{"(", 
         RowBox[{"530", " ", "+", " ", 
          RowBox[{"20", "*", "x"}]}], ")"}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1", ",", " ", "64"}], "}"}]}], "]"}], "//", 
     "MatrixForm"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Time", " ", "allocation"}], "*)"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"1.125", 
        RowBox[{"gauss", "[", 
         RowBox[{"0.125", ",", "0.135"}], "]"}]}], "+", 
       RowBox[{"1.125", 
        RowBox[{"gauss", "[", 
         RowBox[{"0.96", ",", "0.15"}], "]"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gauss", "[", 
     RowBox[{"\[Mu]_", ",", "\[Sigma]_", ",", "x_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"2", "\[Pi]", " ", "\[Sigma]"}], "]"}], ")"}]}], "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Mu]", "-", "x"}], ")"}], "^", "2"}]}], "/", 
       RowBox[{"(", 
        RowBox[{"2", "\[Sigma]"}], ")"}]}], "]"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tot", "=", 
     RowBox[{"Re", "[", 
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"1.125", 
          RowBox[{"gauss", "[", 
           RowBox[{"0.125", ",", "0.135"}], "]"}]}], "+", 
         RowBox[{"1.125", 
          RowBox[{"gauss", "[", 
           RowBox[{"0.96", ",", "0.15"}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], "]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"f1", "[", "x_", "]"}], ":=", 
    RowBox[{
     RowBox[{"1.", "/", "tot"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"1.125", 
        RowBox[{"gauss", "[", 
         RowBox[{"0.125", ",", "0.115", ",", "x"}], "]"}]}], "+", 
       RowBox[{"1.125", 
        RowBox[{"gauss", "[", 
         RowBox[{"0.96", ",", "0.15", ",", "x"}], "]"}]}]}], ")"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f1", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "0.2"}], ",", "1.2"}], "}"}]}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"timeMS", "=", "10000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"incMS", "=", "6000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"totMS", "=", 
     RowBox[{"timeMS", "+", "incMS"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"moves", "=", 
     RowBox[{"45", "-", "30"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"timePerMove", "=", 
     RowBox[{"2.5", "*", 
